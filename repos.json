[
  {
    "kernelSource": {
      "name": "kernel_lge_sm8250",
      "repo": "https://github.com/tu-usuario/kernel_lge_sm8250",
      "branch": "master",
      "device": "v60"
    },
    "toolchains": [
      {
        "name": "clang",
        "repo": "https://github.com/ZyCromerZ/Clang",
        "branch": "18"
      },
      {
        "name": "gcc-64",
        "repo": "https://github.com/mvaisakh/gcc-arm64",
        "branch": "gcc-master"
      },
      {
        "name": "gcc-32",
        "repo": "https://github.com/mvaisakh/gcc-arm",
        "branch": "gcc-master"
      }
    ],
    "params": {
      "ARCH": "arm64",
      "CC": "clang",
      "NM": "llvm-nm",
      "OBJCOPY": "llvm-objcopy",
      "OBJDUMP": "llvm-objdump",
      "STRIP": "llvm-strip",
      "LD": "ld.lld",
      "AR": "llvm-ar",
      "CROSS_COMPILE": "aarch64-elf-",
      "CROSS_COMPILE_ARM32": "arm-eabi-",
      "CLANG_TRIPLE": "aarch64-linux-gnu-",
      "EXTRA_CFLAGS": "-Wno-error"
    },
    "withKernelSU": "true"
  }
]
